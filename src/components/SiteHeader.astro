---
import { business } from "../data/business";
import { primaryNav } from "../data/navigation";

const pathname = Astro.url.pathname;

const isActive = (href: string) => {
  if (href === "/") {
    return pathname === "/";
  }

  return pathname.startsWith(href);
};
---

<header class="site-header">
  <div class="container header-row">
    <a href="/" class="brand" aria-label="Sombrero Painting Home">
      <span class="brand-mark" aria-hidden="true">SP</span>
      <span class="brand-copy">
        <span class="brand-name">Sombrero Painting</span>
        <span class="brand-tag">Residential Painting in Phoenix Metro</span>
      </span>
    </a>

    <nav class="desktop-nav" aria-label="Primary">
      <ul>
        {primaryNav.map((item) => (
          <li>
            <a
              href={item.href}
              class={isActive(item.href) ? "active" : undefined}
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-actions">
      <a class="phone-link" href={`tel:${business.phoneHref}`} aria-label={`Call ${business.name} at ${business.phoneDisplay}`}>
        {business.phoneDisplay}
      </a>
      <a class="btn btn-primary header-cta" href="/contact/">Get Free Estimate</a>
    </div>

    <details class="mobile-nav-wrap">
      <summary aria-label="Open menu">Menu</summary>
      <nav aria-label="Mobile">
        <ul>
          {primaryNav.map((item) => (
            <li>
              <a
                href={item.href}
                class={isActive(item.href) ? "active" : undefined}
                aria-current={isActive(item.href) ? "page" : undefined}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
        <div class="mobile-cta-row">
          <a class="btn btn-primary btn-block" href="/contact/">Get Free Estimate</a>
          <a class="phone-link mobile-phone" href={`tel:${business.phoneHref}`}>
            Call {business.phoneDisplay}
          </a>
        </div>
      </nav>
    </details>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 120;
    background: rgb(255 255 255 / 94%);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgb(211 222 233 / 90%);
    box-shadow: 0 6px 22px rgb(10 29 46 / 5%);
  }

  .header-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.3rem;
    min-height: 5.7rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    text-decoration: none;
  }

  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.7rem;
    height: 2.7rem;
    border-radius: 0.8rem;
    border: 1px solid #2b5b83;
    background: linear-gradient(160deg, #184c78 0%, #12395d 100%);
    color: #fff;
    font-weight: 700;
    font-size: 0.94rem;
    letter-spacing: 0.05em;
    box-shadow: 0 8px 16px rgb(18 57 93 / 18%);
  }

  .brand-copy {
    display: flex;
    flex-direction: column;
    gap: 0.08rem;
    line-height: 1.1;
  }

  .brand-name {
    font-family: "Merriweather", Georgia, serif;
    font-size: 1.08rem;
    color: #0d2841;
    font-weight: 700;
  }

  .brand-tag {
    font-size: 0.77rem;
    color: var(--color-muted);
    letter-spacing: 0.015em;
  }

  .desktop-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    justify-content: center;
    gap: 1.15rem;
    flex-wrap: wrap;
  }

  .desktop-nav a {
    text-decoration: none;
    color: #1b3650;
    font-weight: 700;
    font-size: 0.94rem;
    letter-spacing: 0.012em;
    padding: 0.22rem 0;
    border-bottom: 2px solid transparent;
  }

  .desktop-nav a.active,
  .desktop-nav a:hover {
    color: #0e2f4d;
    border-bottom-color: var(--color-accent);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }

  .header-cta {
    min-height: 2.7rem;
    padding-inline: 1.08rem;
  }

  .phone-link {
    text-decoration: none;
    font-weight: 700;
    color: #0f3759;
    white-space: nowrap;
    border: 1px solid #c6d6e4;
    border-radius: 999px;
    padding: 0.54rem 0.9rem;
    background: linear-gradient(180deg, #f8fbfd 0%, #eef5fa 100%);
  }

  .phone-link:hover {
    border-color: #9cb8d1;
    background: #edf4fa;
  }

  .mobile-nav-wrap {
    display: none;
  }

  @media (max-width: 1024px) {
    .desktop-nav,
    .header-actions {
      display: none;
    }

    .header-row {
      grid-template-columns: 1fr auto;
      min-height: 5.15rem;
    }

    .mobile-nav-wrap {
      display: block;
      justify-self: end;
      position: relative;
    }

    .mobile-nav-wrap summary {
      list-style: none;
      cursor: pointer;
      border: 1px solid var(--color-border);
      border-radius: 999px;
      padding: 0.52rem 0.98rem;
      font-weight: 700;
      color: #17364f;
      background: #fff;
    }

    .mobile-nav-wrap[open] nav {
      position: absolute;
      right: 0;
      top: calc(100% + 0.55rem);
      min-width: 17.5rem;
      background: #fff;
      border: 1px solid var(--color-border);
      border-radius: 1rem;
      padding: 1rem;
      box-shadow: var(--shadow-md);
    }

    .mobile-nav-wrap nav ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 0.24rem;
    }

    .mobile-nav-wrap nav a {
      display: block;
      text-decoration: none;
      color: #1a344c;
      font-weight: 700;
      padding: 0.52rem 0.45rem;
      border-radius: 0.5rem;
    }

    .mobile-nav-wrap nav a.active,
    .mobile-nav-wrap nav a:hover {
      background: #edf4fa;
      color: #0d2f4b;
    }

    .mobile-cta-row {
      display: grid;
      gap: 0.65rem;
      margin-top: 0.9rem;
    }

    .mobile-phone {
      display: block;
      text-align: center;
      border-color: #90afca;
      background: #f6fbff;
      padding: 0.62rem 0.9rem;
    }
  }

  @media (max-width: 500px) {
    .brand-tag {
      display: none;
    }
  }
</style>
