---
interface Props {
  id?: string;
  title?: string;
  lead?: string;
  alternate?: boolean;
}

const { id, title, lead, alternate = false } = Astro.props;
---

<section id={id} class:list={["section", alternate && "section-alt"]}>
  <div class="container">
    {title && <h2 class="section-title">{title}</h2>}
    {lead && <p class="section-lead">{lead}</p>}
    <slot />
  </div>
</section>
