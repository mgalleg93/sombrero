---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  highlights?: string[];
}

const {
  eyebrow,
  title,
  subtitle,
  primaryLabel,
  primaryHref,
  secondaryLabel,
  secondaryHref,
  highlights = [],
} = Astro.props;
---

<section class="section hero">
  <div class="container split hero-wrap">
    <div class="hero-content">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      <p class="section-lead hero-lead">{subtitle}</p>
      <div class="btn-row hero-actions">
        <a class="btn btn-primary" href={primaryHref}>{primaryLabel}</a>
        {secondaryLabel && secondaryHref && (
          <a class="btn btn-secondary" href={secondaryHref}>{secondaryLabel}</a>
        )}
      </div>
      <p class="hero-note">Free estimates for homeowners in Phoenix and Glendale, AZ.</p>
    </div>

    <aside class="panel hero-panel">
      <p class="badge">Trusted Local Service</p>
      <h2>Why homeowners call us</h2>
      {highlights.length > 0 ? (
        <ul class="list-check">
          {highlights.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      ) : (
        <p>Professional residential painting with clear communication and respectful crews.</p>
      )}
    </aside>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(3.35rem, 6vw, 5.75rem);
    background:
      radial-gradient(circle at 14% 12%, #e2edf7 0, transparent 50%),
      radial-gradient(circle at 88% 10%, #eef4f8 0, transparent 44%);
  }

  .hero-wrap {
    align-items: center;
  }

  .hero-content {
    max-width: 44rem;
  }

  .hero-content h1 {
    max-width: 18ch;
    margin-bottom: 0.92rem;
  }

  .hero-lead {
    max-width: 61ch;
  }

  .hero-actions {
    margin-top: 0.25rem;
  }

  .hero-note {
    margin-top: 0.9rem;
    color: #5b7084;
    font-weight: 600;
    font-size: 0.98rem;
  }

  .hero-panel {
    display: grid;
    gap: 0.55rem;
    min-height: 100%;
  }

  .hero-panel .badge {
    justify-self: start;
  }

  .hero-panel .list-check {
    margin-top: 0.8rem;
  }
</style>
