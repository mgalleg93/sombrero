---
import { business } from "../data/business";
import { cities } from "../data/cities";
import { footerQuickLinks } from "../data/navigation";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <section>
      <h3>{business.name}</h3>
      <p>{business.foundedMessage}</p>
      <p class="seo-line">{business.serviceAreaSummary}</p>
      <p>
        <a href={`tel:${business.phoneHref}`}>{business.phoneDisplay}</a><br />
        <a href={`mailto:${business.email}`}>{business.email}</a>
      </p>
    </section>

    <section>
      <h3>Quick Links</h3>
      <ul>
        {footerQuickLinks.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </section>

    <section>
      <h3>Service Areas</h3>
      <ul>
        {cities.map((city) => (
          <li><a href={`/service-areas/${city.slug}/`}>{city.name}, AZ</a></li>
        ))}
      </ul>
      <p class="footer-note">Residential-only painting for custom homes and tract homes.</p>
    </section>
  </div>

  <div class="footer-bar">
    <div class="container footer-bar-row">
      <p>&copy; {year} {business.name}. All rights reserved.</p>
      <a class="footer-call" href={`tel:${business.phoneHref}`}>Call {business.phoneDisplay}</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 2.5rem;
    background: linear-gradient(165deg, #0d2740 0%, #0a2238 100%);
    color: #e8f1fb;
  }

  .footer-grid {
    padding: 3rem 0 2.35rem;
    display: grid;
    grid-template-columns: 1.35fr 1fr 1fr;
    gap: 1.6rem;
  }

  .site-footer h3 {
    color: #fff;
    margin-bottom: 0.78rem;
    font-size: 1.08rem;
  }

  .site-footer p {
    margin-bottom: 0.82rem;
    color: #d6e4f0;
    max-width: 42ch;
  }

  .site-footer a {
    color: #f0f6ff;
    text-decoration-color: #8fb3d5;
  }

  .site-footer ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.42rem;
  }

  .site-footer li a {
    text-decoration: none;
  }

  .site-footer li a:hover {
    text-decoration: underline;
  }

  .seo-line {
    font-weight: 700;
    color: #f2c28f;
  }

  .footer-note {
    margin-top: 0.92rem;
    font-size: 0.95rem;
    color: #c9d9e8;
  }

  .footer-bar {
    border-top: 1px solid rgb(255 255 255 / 16%);
    padding: 0.92rem 0;
  }

  .footer-bar-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .footer-bar p {
    margin: 0;
    color: #b9cfdf;
    font-size: 0.91rem;
  }

  .footer-call {
    border: 1px solid #5f84a7;
    border-radius: 999px;
    padding: 0.42rem 0.76rem;
    text-decoration: none;
    font-weight: 700;
    color: #f5faff;
    background: rgb(255 255 255 / 7%);
  }

  .footer-call:hover {
    border-color: #88a9c8;
    background: rgb(255 255 255 / 11%);
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 1.35rem;
      padding: 2.3rem 0 1.95rem;
    }
  }
</style>
