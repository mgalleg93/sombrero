---
export type FaqItem = {
  question: string;
  answer: string;
};

interface Props {
  title?: string;
  faqs: FaqItem[];
}

const { title = "Frequently Asked Questions", faqs } = Astro.props;
---

<section class="faq-block" aria-label={title}>
  <h2 class="section-title">{title}</h2>
  <div class="faq-list">
    {faqs.map((faq) => (
      <details class="card">
        <summary>{faq.question}</summary>
        <p>{faq.answer}</p>
      </details>
    ))}
  </div>
</section>

<style>
  .faq-list {
    display: grid;
    gap: 0.82rem;
  }

  details {
    padding: 0.92rem 1.02rem;
    border-top: 4px solid #dbe8f3;
  }

  summary {
    font-weight: 700;
    color: #173551;
    padding-right: 1.4rem;
  }

  details p {
    margin-top: 0.72rem;
    color: #465a6d;
  }
</style>
