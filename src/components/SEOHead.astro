---
interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  image?: string;
  imageAlt?: string;
  noIndex?: boolean;
  type?: "website" | "article";
  schemas?: unknown[];
}

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  image = "/images/og-default.svg",
  imageAlt = "Sombrero Painting residential painting services in Phoenix and Glendale, AZ",
  noIndex = false,
  type = "website",
  schemas = [],
} = Astro.props;

const siteOrigin = Astro.site ? Astro.site.toString().replace(/\/$/, "") : "";
const normalizedPath = canonicalPath.startsWith("/") ? canonicalPath : `/${canonicalPath}`;
const canonicalUrl = siteOrigin ? `${siteOrigin}${normalizedPath}` : normalizedPath;
const imagePath = image.startsWith("/") ? image : `/${image}`;
const imageUrl = image.startsWith("http") ? image : `${siteOrigin}${imagePath}`;
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
<meta name="robots" content={noIndex ? "noindex, nofollow" : "index, follow"} />

<meta property="og:type" content={type} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={imageUrl} />
<meta property="og:image:alt" content={imageAlt} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content="Sombrero Painting" />
<meta property="og:locale" content="en_US" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
<meta name="twitter:image:alt" content={imageAlt} />

{schemas.map((schema) => <script type="application/ld+json" set:html={JSON.stringify(schema)} />)}
